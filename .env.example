# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Neo4j / Graphiti 自托管知识图谱配置 =====
# 需在 docker-compose 中启动 Neo4j 服务（已内置）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
# 向量嵌入配置（Graphiti 需要 embedding API，DeepSeek 不提供此接口）
# 推荐使用 OpenAI text-embedding-3-small（成本极低）
# 若 LLM 服务商支持 embedding，可将下面两项指向同一 base_url
GRAPHITI_EMBEDDING_API_KEY=your_openai_api_key_here
GRAPHITI_EMBEDDING_BASE_URL=https://api.openai.com/v1
GRAPHITI_EMBEDDING_MODEL=text-embedding-3-small

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
